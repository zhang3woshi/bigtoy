# Copy this file to conf/secrets.env and fill real values.
# conf/secrets.env is ignored by git.

# Admin auth
BIGTOY_ADMIN_USER=admin
BIGTOY_ADMIN_PASSWORD_HASH=$2a$10$replace_with_bcrypt_hash

# HTTPS for public deployment
BIGTOY_FORCE_HTTPS=true
BIGTOY_ENABLE_HTTP=false
BIGTOY_ENABLE_HTTPS=true
BIGTOY_HTTPS_ADDR=0.0.0.0
BIGTOY_HTTPS_PORT=11001
BIGTOY_HTTPS_CERT_FILE=conf/certs/fullchain.pem
BIGTOY_HTTPS_KEY_FILE=conf/certs/privkey.pem
BIGTOY_AUTH_SECURE_COOKIE=true

# CORS allowlist
BIGTOY_ALLOWED_ORIGINS=https://your-domain.com
